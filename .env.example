# ======= Blogicum FastAPI — пример переменных окружения =======
# Скопируйте файл в .env и при необходимости измените значения.

APP_NAME=Blogicum API
APP_VERSION=1.0.0
DEBUG=False

# Для локального запуска без Docker можно использовать SQLite:
# DATABASE_URL=sqlite:///./blogicum.db
DATABASE_URL=postgresql+psycopg2://blogicum:blogicum@db:5432/blogicum

SECRET_KEY=change_me_for_production_super_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

LOG_LEVEL=INFO
LOG_FILE=logs/blogicum.log

POSTGRES_USER=blogicum
POSTGRES_PASSWORD=blogicum
POSTGRES_DB=blogicum
